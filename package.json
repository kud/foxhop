{
  "name": "foxhop",
  "version": "0.0.0",
  "description": "Fox Hop — focus a Firefox tab by URL. Monorepo: CLI native host + browser extension.",
  "private": true,
  "license": "MIT",
  "author": "kud",
  "type": "module",
  "workspaces": [
    "cli",
    "extension"
  ],
  "scripts": {
    "build": "npm run build -w cli",
    "typecheck": "npm run typecheck -w cli",
    "test": "npm run test -w cli",
    "lint": "npm run lint -w extension",
    "dev:cli": "npm run dev -w cli",
    "dev:ext": "npm run dev -w extension",
    "sign:listed": "npm run sign:listed -w extension",
    "sign:self": "npm run sign:self -w extension",
    "publish:ext": "npm run publish -w extension",
    "release:cli": "bin/release.sh",
    "release:ext": "bin/release-ext.sh"
  }
}
