{
  "name": "foxhop",
  "version": "0.0.0",
  "description": "Fox Hop — focus a Firefox tab by URL. Monorepo: CLI native host + browser extension.",
  "private": true,
  "license": "MIT",
  "author": "kud",
  "type": "module",
  "workspaces": [
    "cli",
    "webextension"
  ],
  "scripts": {
    "build": "npm run build -w cli",
    "typecheck": "npm run typecheck -w cli",
    "test": "npm run test -w cli",
    "lint": "npm run lint -w webextension",
    "dev:cli": "npm run dev -w cli",
    "dev:webext": "npm run dev -w webextension",
    "sign:listed": "npm run sign:listed -w webextension",
    "sign:self": "npm run sign:self -w webextension",
    "publish:webext": "npm run publish -w webextension",
    "release:cli": "bin/release.sh",
    "release:webext": "bin/release-webext.sh"
  }
}
