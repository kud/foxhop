{
  "name": "@kud/foxhop-cli",
  "version": "1.1.3",
  "description": "foxhop CLI and native messaging host — focus specific Firefox tabs from macOS",
  "type": "module",
  "license": "MIT",
  "author": "Erwann Mest <m@kud.io>",
  "homepage": "https://github.com/kud/foxhop#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kud/foxhop.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/kud/foxhop/issues"
  },
  "keywords": [
    "firefox",
    "macos",
    "raycast",
    "cli",
    "tabs",
    "native-messaging",
    "focus"
  ],
  "bin": {
    "foxhop": "./dist/cli.js",
    "foxhop-host": "./dist/host-cli.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "citty": "0.2.2"
  },
  "devDependencies": {
    "@types/node": "26.0.0",
    "tsup": "8.5.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
