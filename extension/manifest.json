{
  "manifest_version": 2,
  "name": "Fox Hop",
  "description": "Focus a specific Firefox tab on command — driven by the foxhop CLI and Raycast.",
  "version": "1.0.2",
  "browser_specific_settings": {
    "gecko": {
      "id": "foxhop@kud.io",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": ["tabs", "nativeMessaging"],
  "background": {
    "scripts": ["src/background.js"]
  },
  "browser_action": {
    "default_title": "Fox Hop",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "src/icons/icon.svg",
      "32": "src/icons/icon.svg"
    }
  },
  "icons": {
    "48": "src/icons/icon.svg",
    "96": "src/icons/icon.svg",
    "128": "src/icons/icon.svg"
  }
}
